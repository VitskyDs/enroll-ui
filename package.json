{
  "name": "@vitskyds/enroll-ui",
  "version": "0.1.0",
  "description": "Enroll design system — components, tokens, and theming for the Enroll loyalty platform",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind/preset.d.ts",
      "import": "./dist/tailwind/preset.js",
      "require": "./dist/tailwind/preset.cjs"
    },
    "./styles": "./dist/styles/base.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npm run copy:css",
    "copy:css": "mkdir -p dist/styles && cp src/styles/base.css dist/styles/base.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/public-sans": "^5.2.7",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.4.0",
    "typescript": "~6.0.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
